#!/bin/zsh
set -euo pipefail

# Claude Code CLI auto-mode wrapper for macOS.
# This is a startup wrapper, not a global button clicker.

PROVENANCE="CLAUDE-CLI-AUTO-POSITIVEF-2026-07"
SCRIPT_DIR="${0:A:h}"
policy_file=""
cli_permission_mode="Auto"

policy_candidates=()
if [[ -n "${CLAUDE_AUTO_ALLOW_POLICY_FILE:-}" ]]; then
  policy_candidates+=("$CLAUDE_AUTO_ALLOW_POLICY_FILE")
fi
policy_candidates+=("$SCRIPT_DIR/auto-allow-policy.json" "$SCRIPT_DIR/../auto-allow-policy.json")

for candidate in "${policy_candidates[@]}"; do
  if [[ -n "$candidate" && -f "$candidate" ]]; then
    policy_file="${candidate:A}"
    break
  fi
done

if [[ -n "$policy_file" ]]; then
  policy_value="$(sed -nE 's/.*"cliPermissionMode"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/p' "$policy_file" | head -n 1 | tr -d '\r')"
  case "$policy_value" in
    Manual|manual)
      cli_permission_mode="Manual"
      ;;
    Auto|auto|"")
      cli_permission_mode="Auto"
      ;;
  esac
fi

has_permission_override=false
for arg in "$@"; do
  case "$arg" in
    --dangerously-skip-permissions|--allow-dangerously-skip-permissions|--permission-mode|--permission-mode=*)
      has_permission_override=true
      break
      ;;
  esac
done

final_args=()
if [[ "$has_permission_override" == false && "$cli_permission_mode" == "Auto" ]]; then
  final_args+=(--permission-mode auto)
fi
final_args+=("$@")

task_summary() {
  local skip_next=false
  local parts=()
  local arg

  for arg in "$@"; do
    if [[ "$skip_next" == true ]]; then
      skip_next=false
      continue
    fi

    case "$arg" in
      --permission-mode|--model|--agent|--name)
        skip_next=true
        continue
        ;;
      --permission-mode=*)
        continue
        ;;
      -*)
        continue
        ;;
    esac

    parts+=("$arg")
  done

  local summary="${(j: :)parts}"
  if [[ -z "$summary" ]]; then
    summary="interactive session"
  fi

  if (( ${#summary} > 72 )); then
    summary="${summary[1,69]}..."
  fi

  print -r -- "$summary"
}

normalize_topic_text() {
  print -r -- "$1" | tr -d '\000-\010\013\014\016-\037\177' | tr '\t\r\n' ' ' | sed -E 's/[[:space:]]+/ /g; s/^ //; s/ $//'
}

topic_summary() {
  if [[ -n "${CLAUDE_AUTO_ALLOW_TOPIC:-}" ]]; then
    local env_topic
    env_topic="$(normalize_topic_text "$CLAUDE_AUTO_ALLOW_TOPIC")"
    if (( ${#env_topic} > 72 )); then
      env_topic="${env_topic[1,69]}..."
    fi
    print -r -- "$env_topic"
    return 0
  fi

  normalize_topic_text "$(task_summary "$@")"
}

topic_source() {
  if [[ -n "${CLAUDE_AUTO_ALLOW_TOPIC:-}" ]]; then
    print -r -- "CLAUDE_AUTO_ALLOW_TOPIC"
    return 0
  fi

  local computed
  computed="$(task_summary "$@")"
  if [[ "$computed" == "interactive session" ]]; then
    print -r -- "default"
  else
    print -r -- "command arguments"
  fi
}

resolve_claude() {
  if [[ -n "${CLAUDE_BIN:-}" && -x "${CLAUDE_BIN:-}" ]]; then
    print -r -- "$CLAUDE_BIN"
    return 0
  fi

  local candidate
  for candidate in \
    "$HOME/.npm-global/bin/claude" \
    "$HOME/.local/bin/claude" \
    "/opt/homebrew/bin/claude" \
    "/usr/local/bin/claude"; do
    if [[ -x "$candidate" ]]; then
      print -r -- "$candidate"
      return 0
    fi
  done

  candidate="$(command -v claude 2>/dev/null || true)"
  if [[ -n "$candidate" && -x "$candidate" ]]; then
    print -r -- "$candidate"
    return 0
  fi

  return 1
}

claude_bin="$(resolve_claude)" || {
  print -u2 "Claude Code CLI was not found. Install Claude Code on this Mac first."
  exit 1
}

project_path="$PWD"
project_name="${PWD:t}"
if [[ -z "$project_name" ]]; then
  project_name="$project_path"
fi
topic="$(topic_summary "$@")"
topic_src="$(topic_source "$@")"
short_mode_label="AUTO"
mode_text="CLI policy Auto; --permission-mode auto injected"
if [[ "$has_permission_override" == true ]]; then
  short_mode_label="OVERRIDE"
  mode_text="permission override supplied by user"
elif [[ "$cli_permission_mode" == "Manual" ]]; then
  short_mode_label="MANUAL"
  mode_text="CLI policy Manual; no --permission-mode injected"
fi

print -Pn "\e]0;Claude CLI | Project=$project_name | Mode=$short_mode_label | Topic=$topic\a"

print "=== CLAUDE CLI AUTO WRAPPER ACTIVE ==="
print "Project : $project_name"
print "Path    : $project_path"
print "Status  : launching Claude Code under wrapper"
print "Topic   : $topic"
print "TopicSrc: $topic_src"
print "Mode    : $mode_text"
if [[ -n "$policy_file" ]]; then
  print "Policy  : $policy_file"
else
  print "Policy  : not found; default CLI Auto"
fi
print "Title   : Project + Mode + Topic are shown in the terminal title bar"
print "Owner   : positivef"
print "Marker  : $PROVENANCE"
print
print -P "%F{8}[macos-claude-cli-auto-wrapper] ${(q)claude_bin} ${(@q)final_args}%f"

exec "$claude_bin" "${final_args[@]}"
